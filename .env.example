# ═══════════════════════════════════════════════════════════════════════════
# GLS Admin / Space Memory — Environment Configuration
# ═══════════════════════════════════════════════════════════════════════════
#
# Скопируйте этот файл как .env.local или .env и настройте под себя.
# Все VITE_* переменные доступны в клиентском приложении, поэтому
# НЕ храните здесь секреты, токены и пароли.
#

# ── Базовые настройки приложения ──────────────────────────────────────────
VITE_APP_TITLE=Memori · Payments
VITE_DEFAULT_PROJECT=space_ua

# ── API по проектам ───────────────────────────────────────────────────────
# Legacy fallback для активного проекта (используется также прокси Vite)
VITE_API_URL=https://URl_UA/api/v1/

# API по проектам: suffix /api/v1/ будет добавлен автоматически при необходимости
VITE_API_URL_SPACE=https://pl.memory.firm.kiev.ua
VITE_API_URL_INDIGO=https://URL_INDIGO/api/v1/
VITE_API_URL_SPACE_UA=https://URL.ua/api/v1/

# ── Recruitment API URLs ──────────────────────────────────────────────────
VITE_RECRUITMENT_API_URL=https://space-memory.edugls.com/api/v1/
VITE_RECRUITMENT_INDIGO_API_URL=https://indigo.edugls.com/api/v1/

# ── Метаданные проектов для UI ────────────────────────────────────────────
VITE_PROJECT_LABEL_SPACE=Space Memory PL
VITE_PROJECT_SHORT_LABEL_SPACE=Space PL
VITE_PROJECT_PUBLIC_URL_SPACE=https://space-memory.pl

VITE_PROJECT_LABEL_SPACE_UA=Space Memory UA
VITE_PROJECT_SHORT_LABEL_SPACE_UA=Space UA
VITE_PROJECT_PUBLIC_URL_SPACE_UA=

VITE_PROJECT_LABEL_INDIGO=Indigo
VITE_PROJECT_SHORT_LABEL_INDIGO=Indigo
VITE_PROJECT_PUBLIC_URL_INDIGO=https://indigomental.pl

# ── Mock / Real API routing ───────────────────────────────────────────────
# true  = все запросы по умолчанию идут в mockAdapter.ts
# false = все запросы по умолчанию идут на реальный бэкенд
VITE_USE_MOCK=false

# Префиксы URL (через запятую), которые всегда идут в mock / real
VITE_MOCK_ONLY=
VITE_REAL_ONLY=

# ── Temporary authz bypass (incident mode) ────────────────────────────────
# true  = все авторизованные пользователи получают полный доступ
# false = используется обычная ролевая модель
VITE_AUTHZ_BYPASS=true

