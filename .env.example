# ═══════════════════════════════════════════════════════════════════════════
# GLS Admin / Space Memory — Environment Configuration
# ═══════════════════════════════════════════════════════════════════════════
#
# Скопируйте этот файл как .env.local и настройте под себя:
#   cp .env.example .env.local
#

# ── Основной API URL ──────────────────────────────────────────────────────
# Базовый URL бэкенда Space Memory (все запросы кроме recruitment идут сюда)
VITE_API_URL=https://memory.firm.kiev.ua/api/v1/

# ── Recruitment API URLs ──────────────────────────────────────────────────
# Бэкенд для рекрутинга Space Memory (по умолчанию = VITE_API_URL)
VITE_RECRUITMENT_API_URL=https://memory.firm.kiev.ua/api/v1/

# Бэкенд для рекрутинга INDIGO (Speedy Mind) — отдельный Laravel-проект
VITE_RECRUITMENT_INDIGO_API_URL=https://indigo.firm.kiev.ua/api/v1/

# ── Mock / Real API routing ──────────────────────────────────────────────
#
# VITE_USE_MOCK — глобальный флаг:
#   true  = ВСЕ запросы идут в mockAdapter.ts (режим прототипа)
#   false = ВСЕ запросы идут на реальный бэкенд (продакшен)
#
VITE_USE_MOCK=false

# VITE_REAL_ONLY — список URL-префиксов (через запятую), которые
# ВСЕГДА идут на реальный бэкенд, ДАЖЕ если VITE_USE_MOCK=true.
# Используйте для постепенного подключения модулей.
#
# Примеры:
#   VITE_REAL_ONLY=recruitment/new-students,recruitment/leads
#   VITE_REAL_ONLY=recruitment,expelled-students,auth
#
VITE_REAL_ONLY=

# URL основного API сервера
VITE_API_URL=https://127.0.0.1:8080/api/v1/

# URL второго API сервера для recruitment
VITE_RECRUITMENT_API_URL=https://127.0.0.1:8081/api/v1/

VITE_RECRUITMENT_INDIGO_API_URL=hhttps://127.0.0.1:8082/api/v1/

VITE_AUTHZ_BYPASS=true

# VITE_MOCK_ONLY — список URL-префиксов (через запятую), которые
# ВСЕГДА идут на mockAdapter, ДАЖЕ если VITE_USE_MOCK=false.
# Используйте для модулей, бэкенд которых ещё не готов.
#
# Примеры:
#   VITE_MOCK_ONLY=salary,student/notes,archived-students
#   VITE_MOCK_ONLY=payments,new-groups
#
VITE_MOCK_ONLY=

# ── Temporary authz bypass (incident mode) ─────────────────────────────────
# true  = все авторизованные пользователи получают доступ как до ролей
# false = используется ROLE_MENU_ACCESS и обычная ролевая модель
VITE_AUTHZ_BYPASS=true

