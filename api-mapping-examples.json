    "issues": [
      {
        "field": "age",
        "problem": "Отрицательное значение: -6.23",
        "reason": "Дата рождения в будущем (2019-12-13 vs 2026-03-07)",
        "solution": "Добавить валидацию: age = max(0, now - dob)"
      },
      {
        "field": "firstName/lastName",
        "problem": "Путаница в названиях",
        "reason": "В БД surname=фамилия, lastname=имя",
        "solution": "Правильное сопоставление в коде"
      },
      {
        "field": "totalBalance.value",
        "problem": "Разные форматы",
        "api": "\"0.00\"",
        "mock": "\"+220 zł\"",
        "solution": "Форматировать на frontend"
      },
      {
        "field": "nextPay.date",
        "problem": "Разные форматы дат",
        "api": "\"\" или \"2026-03-01\" (ISO)",
        "mock": "\"01.03.2026\" (DD.MM.YYYY)",
        "solution": "Использовать ISO 8601 в API, форматировать на frontend"
      }
    ]
  },

  "databaseSchema": {
    "student": {
      "tableName": "student",
      "primaryKey": "id",
      "columns": {
        "id": "integer",
        "surname": "string (фамилия!)",
        "lastname": "string (имя!)",
        "email": "string",
        "dob": "date",
        "phone": "string",
        "balance": "decimal",
        "sum_aboniment": "integer",
        "date_finish": "date",
        "enabled": "boolean",
        "parent1_surname": "string",
        "parent1_lastname": "string",
        "parent1_phone": "string",
        "parent1_phone_country": "string"
      }
    },
    "student_payment": {
      "tableName": "student_payment",
      "primaryKey": "id",
      "foreignKeys": {
        "student_id": "student.id"
      },
      "columns": {
        "id": "integer",
        "student_id": "integer",
        "date_pay": "date",
        "date_finish": "date",
        "sum_aboniment": "integer",
        "type_pay": "string",
        "discount": "integer",
        "enabled": "boolean (оплачен?)"
      }
    }
  },

